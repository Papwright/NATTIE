{
  "builds": [
    { "src": "dist/server/server.js", "use": "@vercel/edge" },
    { "src": "dist/client/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/assets/(.*)", "dest": "dist/client/assets/$1" },
    { "src": "^/audio/(.*)", "dest": "dist/client/assets/audio/$1" },
    { "src": "^/gifs/(.*)", "dest": "dist/client/assets/gifs/$1" },
    { "src": "^/(.*)", "dest": "dist/server/server.js" }
  ]
}
